{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Captain's Log",
  "version": "1.0.0",
  "identifier": "com.maxv.captainslog",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**/*", "$APPCACHE/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["../captainsloglogo.png", "../favicon.ico"],
    "resources": {
      "../plugins/": "plugins/",
      "../captainsloglogo.png": "captainsloglogo.png",
      "../favicon.ico": "favicon.ico",
      "../public/assets/figtree.ttf": "figtree.ttf"
    }
  }
}
